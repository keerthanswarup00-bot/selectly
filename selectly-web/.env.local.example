# ─── Supabase ───────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key (server-side only, NEVER expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── App ────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Selixo

# ─── Upload ─────────────────────────────────────────
# Maximum file size in MB
NEXT_PUBLIC_MAX_FILE_SIZE_MB=20
# Maximum concurrent uploads
NEXT_PUBLIC_UPLOAD_CONCURRENCY=5
# Preview target width in pixels
NEXT_PUBLIC_PREVIEW_WIDTH=1200
# Preview JPEG quality (0-1)
NEXT_PUBLIC_PREVIEW_QUALITY=0.8
